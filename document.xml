put ripple, and load regulation behaviour to confirm stable power delivery under all operating conditions.</w:t></w:r></w:p><w:p w:rsidR="003577D2" w:rsidRDefault="003577D2" w:rsidP="003577D2"><w:pPr><w:pStyle w:val="Paragraphedeliste"/></w:pPr></w:p><w:p w:rsidR="003577D2" w:rsidRDefault="003577D2" w:rsidP="003577D2"><w:pPr><w:pStyle w:val="Paragraphedeliste"/></w:pPr></w:p><w:p w:rsidR="003577D2" w:rsidRDefault="003577D2" w:rsidP="003577D2"><w:pPr><w:pStyle w:val="Paragraphedeliste"/></w:pPr></w:p><w:p w:rsidR="003577D2" w:rsidRDefault="003577D2" w:rsidP="003577D2"><w:pPr><w:pStyle w:val="Paragraphedeliste"/></w:pPr></w:p><w:p w:rsidR="003577D2" w:rsidRDefault="003577D2" w:rsidP="003577D2"><w:pPr><w:pStyle w:val="Paragraphedeliste"/></w:pPr></w:p><w:p w:rsidR="003577D2" w:rsidRDefault="003577D2" w:rsidP="003577D2"><w:pPr><w:pStyle w:val="Paragraphedeliste"/></w:pPr></w:p><w:p w:rsidR="003577D2" w:rsidRDefault="003577D2" w:rsidP="003577D2"><w:pPr><w:pStyle w:val="Paragraphedeliste"/></w:pPr></w:p><w:p w:rsidR="003577D2" w:rsidRDefault="003577D2" w:rsidP="003577D2"><w:pPr><w:pStyle w:val="Paragraphedeliste"/></w:pPr></w:p><w:p w:rsidR="003577D2" w:rsidRDefault="003577D2" w:rsidP="003577D2"><w:pPr><w:pStyle w:val="Paragraphedeliste"/></w:pPr></w:p><w:p w:rsidR="003577D2" w:rsidRDefault="003577D2" w:rsidP="003577D2"/><w:p w:rsidR="003577D2" w:rsidRDefault="003577D2" w:rsidP="003577D2"/><w:p w:rsidR="003577D2" w:rsidRDefault="003577D2" w:rsidP="003577D2"/><w:p w:rsidR="003577D2" w:rsidRDefault="003577D2" w:rsidP="003577D2"/><w:p w:rsidR="003577D2" w:rsidRDefault="003577D2" w:rsidP="003577D2"/><w:p w:rsidR="003577D2" w:rsidRDefault="003577D2" w:rsidP="003577D2"><w:r><w:rPr><w:noProof/><w:lang w:eastAsia="en-GB"/></w:rPr><w:lastRenderedPageBreak/><w:drawing><wp:anchor distT="0" distB="0" distL="114300" distR="114300" simplePos="0" relativeHeight="251660288" behindDoc="0" locked="0" layoutInCell="1" allowOverlap="1"><wp:simplePos x="0" y="0"/><wp:positionH relativeFrom="m