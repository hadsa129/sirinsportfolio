w:proofErr w:type="spellStart"/><w:r><w:t>HyperLynx</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:t xml:space="preserve"> for schematic design, PCB layout, and SI/PI analysis. Strong knowledge of PCBA processes, PCB assembly, design for manufacturability (DFM), and PCB industrialization. Passionate about developing reliable hardware solutions for embedded and electronic systems.</w:t></w:r></w:p><w:p w:rsidR="00886DB9" w:rsidRDefault="00886DB9" w:rsidP="00252427"><w:pPr><w:pStyle w:val="Titre"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:proofErr w:type="spellStart"/><w:r><w:t>Expérience</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:t xml:space="preserve"> </w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:t>Professionnelle</w:t></w:r><w:proofErr w:type="spellEnd"/></w:p><w:p w:rsidR="00252427" w:rsidRPr="00886DB9" w:rsidRDefault="00252427" w:rsidP="00886DB9"><w:pPr><w:pStyle w:val="Titre2"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr><w:rPr><w:b/><w:bCs/><w:color w:val="auto"/></w:rPr></w:pPr><w:r w:rsidRPr="00886DB9"><w:rPr><w:b/><w:bCs/><w:color w:val="auto"/></w:rPr><w:t xml:space="preserve">Freelance Hardware Design Engineer | OTTO </w:t></w:r><w:proofErr w:type="gramStart"/><w:r w:rsidRPr="00886DB9"><w:rPr><w:b/><w:bCs/><w:color w:val="auto"/></w:rPr><w:t xml:space="preserve">ES </w:t></w:r><w:r w:rsidR="000C2506" w:rsidRPr="00886DB9"><w:rPr><w:b/><w:bCs/><w:color w:val="auto"/></w:rPr><w:t xml:space="preserve"> </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidR="000C2506" w:rsidRPr="00886DB9"><w:rPr><w:b/><w:bCs/><w:color w:val="auto"/></w:rPr><w:t>Novembre</w:t></w:r><w:proofErr w:type="spellEnd"/><w:proofErr w:type="gramEnd"/><w:r w:rsidR="000C2506" w:rsidRPr="00886DB9"><w:rPr><w:b/><w:bCs/><w:color w:val="auto"/></w:rPr><w:t xml:space="preserve"> 2025 – Mars 2026</w:t></w:r></w:p><w:p w:rsidR="000C2506" w:rsidRDefault="000C2506" w:rsidP="000C2506"><w:r><w:t>Provided freelance hardware design support f